# Render provides PORT automatically
PORT=8001

# Admin API auth
ADMIN_TOKEN=change-me

# Supabase Postgres (Session pooler or direct)
DATABASE_URL=postgresql://postgres.your-project-ref:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
